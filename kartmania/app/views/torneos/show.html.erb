<div class="container-fluid container-md py-4 px-3 px-lg-5">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">

      <div class="card text-white border-0 custom-card" >
        

        <div class="card-header border-bottom border-white py-3">
        <h2 class="fw-bold mb-0"><%= @torneo.nombre %></h2>
        </div>


        <div class="card-body">
          <div class="row g-4">

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Fecha</p>
              <p class="mb-0"><%= @torneo.fecha_torneo.strftime("%d/%m/%Y %H:%M") %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Dificultad</p>
              <span class="badge mt-1 <%= color_dificultad_torneo(@torneo) %>">
                <p class="mb-0"><%= @torneo.dificultad.humanize %></p>
              </span>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Número de particpantes</p>
              <p class="mb-0"><%= @torneo.numero_participantes %></p>
            </div>


            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Circuito</p>
              <p class="mb-0"><%= @torneo.circuito.present? ? @torneo.circuito.nombre : "Sin circuito asignado" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Primer premio</p>
              <p class="mb-0"><%= @torneo.primer_premio.presence || "No especificada" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Segundo premio</p>
              <p class="mb-0"><%= @torneo.segundo_premio.presence || "No especificada" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Tercer premio</p>
              <p class="mb-0"><%= @torneo.tercer_premio.presence || "No especificada" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Primer puesto</p>
              <p class="mb-0"><%= @torneo.primer_puesto.presence || "No especificada" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Segundo puesto</p>
              <p class="mb-0"><%= @torneo.segundo_puesto.presence || "No especificada" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Primer premio</p>
              <p class="mb-0"><%= @torneo.tercer_puesto.presence || "No especificada" %></p>
            </div>            

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Descripcion/p>
              <p class="mb-0"><%= @torneo.descripcion.presence || "No especificada" %></p>
            </div>            


          </div>
        </div>


        <div class="card-footer border-top border-white d-flex gap-2 justify-content-center py-3">
        <%= link_to edit_torneo_path(@torneo), class: "btn btn-warning fw-bold" do %>
            <i class="fa-solid fa-pen-to-square"></i>
        <% end %>
        <%= link_to torneos_path, class: "btn btn-secondary fw-bold" do %>
            <i class="fa-solid fa-arrow-left"></i> Volver
        <% end %>
        </div>

      </div>

    </div>
  </div>
</div>