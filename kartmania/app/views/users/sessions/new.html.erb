<div class="min-vh-100 d-flex align-items-center justify-content-center">
  <div class="w-100" style="max-width: 420px; padding: 1.5rem;">

    <div class="text-center mb-4">
      <h1 class="fw-bold text-white">Kartmania</h1>
      <p class="text-white-50">Panel de empleados</p>
    </div>

    <div class="card border-0 custom-card">
      <div class="card-body p-4">

        <h2 class="fw-bold text-white text-center mb-4">Iniciar sesión</h2>

    <%= form_with url: user_session_path, scope: :user, data: { turbo: false } do |f| %>

          <%# Errores de Devise %>
          <% if flash[:alert].present? %>
            <div class="alert alert-danger">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <div class="mb-3">
            <%= f.label :email, "Email", class: "form-label fw-bold text-white" %>
            <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "form-control",
                placeholder: "tu@email.com" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "Contraseña", class: "form-label fw-bold text-white" %>
            <%= f.password_field :password,
                autocomplete: "current-password",
                class: "form-control",
                placeholder: "••••••••" %>
          </div>

          <div class="mb-4 form-check">
            <%= f.check_box :remember_me, class: "form-check-input" %>
            <%= f.label :remember_me, "Recordarme", class: "form-check-label text-white" %>
          </div>

          <%= f.submit "Entrar", class: "btn btn-success custom-add-button fw-bold w-100" %>

        <% end %>

        <hr class="border-white-50 my-3">

        <div class="text-center">
          <%= link_to "¿Olvidaste tu contraseña?",
              new_user_password_path,
              class: "text-white-50 small" %>
        </div>

      </div>
    </div>

  </div>
</div>