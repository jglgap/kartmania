<!DOCTYPE html>
<html lang="es">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kartmania</title>
  </head>

  <body style="margin: 0; padding: 0; background-color: #f4f4f4; font-family: Arial, sans-serif;">

    <%# Contenedor principal %>
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f4f4; padding: 30px 0;">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; width: 100%;">

            <%# Cabecera con logo %>
            <tr>
              <td style="background-color: #090056; padding: 24px 32px; border-radius: 8px 8px 0 0; text-align: center;">
                <%= image_tag attachments['logo_kartmania.png'].url,
                    alt:    'Kartmania',
                    style:  'max-height: 60px; width: auto;' %>
              </td>
            </tr>

            <tr>
              <td style="background-color: #ffffff; padding: 32px; border-left: 1px solid #ddd; border-right: 1px solid #ddd;">
                <%= yield %>
              </td>
            </tr>

            <tr>
              <td style="background-color: #090056; padding: 20px 32px; border-radius: 0 0 8px 8px; text-align: center;">
                <p style="margin: 0; color: #ffffff; font-size: 13px;">
                  © <%= Date.current.year %> Kartmania — Todos los derechos reservados
                </p>
                <p style="margin: 8px 0 0; color: #aaaaaa; font-size: 12px;">
                  Este email fue enviado automáticamente, por favor no respondas a este mensaje.
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>

  </body>
</html>