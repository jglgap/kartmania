<div class="container py-4 px-3 px-lg-5">
 <h1 class="fw-bold text-white mb-4">Reservas</h1>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

    <%= form_with url: reservas_path, method: :get, data: { turbo: false } do |f| %>
      <div class="input-group">
        <%= f.text_field :search,
            value: params[:search],
            placeholder: "Filtrar por nombre",
            class: "form-control" %>
        <%= f.button type: :submit, class: "btn btn-outline-light" do %>
          <i class="fa-solid fa-magnifying-glass"></i>
        <% end %>
      </div>
    <% end %>

    <%= link_to new_reserva_path, class: "btn btn-success custom-add-button fw-bold d-flex align-items-center gap-2" do %>
      <span>Crear</span>
      <i class="fa-solid fa-plus"></i>
    <% end %>

  </div>

  <div class="table-responsive">
    <table  id="tabla-user" class="table custom-table text-center align-middle">
      <thead>
        <tr>
          <th>Titular</th>
          <th>Plan</th>
          <th>Fecha estipulada</th>
          <th>Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @reservas.each do |reserva| %>
          <tr>
            <td><%= reserva.cliente_reservas.find(&:es_titular)&.nombre || "sin titular" %></td>
            <td><%= reserva.plan.present? ? reserva.plan.nombre : "sin plan" %></td>
            <td><%= reserva.fecha.strftime("%d/%m/%Y %H:%M") %></td>
            <td data-order="<%= estado_orden(reserva.estado) %>"><%= reserva.estado.humanize %></td>
            <td class="text-nowrap">
              <div class="d-flex gap-2 justify-content-center">


                <%= link_to reserva_path(reserva), class: "btn btn-sm btn-info fw-bold" do %>
                  <i class="fa-solid fa-eye"></i>
                <% end %>


                <%= link_to edit_reserva_path(reserva), class: "btn btn-sm btn-warning fw-bold" do %>
                  <i class="fa-solid fa-pen-to-square"></i>
                <% end %>


                <%= link_to edit_clientes_reserva_path(reserva), class: "btn btn-sm btn-primary fw-bold" do %>
                  <i class="fa-solid fa-user-pen"></i>
                <% end %>

                <%= button_to reserva_path(reserva),
                    method: :delete,
                    data: { turbo: false },
                    class: "btn btn-sm btn-danger fw-bold" do %>
                  <i class="fa-solid fa-trash"></i>
                <% end %>

              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>