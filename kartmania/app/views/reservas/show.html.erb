<div class="container py-4 px-0 px-md-3 px-lg-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">

      <div class="card text-white border-0 custom-card">

        <div class="card-header border-bottom border-white py-3">
          <h2 class="fw-bold mb-0">Reserva #<%= @reserva.id %></h2>
        </div>

        <div class="card-body">


          <div class="row g-4 mb-4">

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Plan</p>
              <p class="mb-0"><%= @reserva.plan.present? ? @reserva.plan.nombre : "Sin plan asignado" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Fecha</p>
              <p class="mb-0"><%= @reserva.fecha.strftime("%d/%m/%Y %H:%M") %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Estado</p>
              <span class="badge <%= @reserva.aceptado? ? 'bg-success' : @reserva.pendiente? ? 'bg-warning' : 'bg-danger' %>">
                <%= @reserva.estado.humanize %>
              </span>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Creada</p>
              <p class="mb-0"><%= @reserva.created_at.strftime("%d/%m/%Y") %></p>
            </div>

          </div>


          <hr class="border-white">


          <h5 class="fw-bold mb-3">Participantes</h5>

          <% @reserva.cliente_reservas.each_with_index do |cr, index| %>
            <div class="card border-white mb-3" style="background: rgba(255,255,255,0.05);">
              <div class="card-header border-bottom border-white py-2 d-flex justify-content-between align-items-center">
                <span class="fw-bold text-white">Participante <%= index + 1 %></span>
                <% if cr.es_titular? %>
                  <span class="badge bg-success">Titular</span>
                <% end %>
              </div>
              <div class="card-body">
                <div class="row g-3">
                  <div class="col-12 col-md-6">
                    <p class="fw-bold mb-1 text-white">Nombre</p>
                    <p class="mb-0 text-white"><%= cr.nombre.presence || "Sin especificar" %></p>
                  </div>
                  <div class="col-12 col-md-6">
                    <p class="fw-bold mb-1 text-white">Email</p>
                    <p class="mb-0 text-white"><%= cr.email.presence || "Sin especificar" %></p>
                  </div>
                  <div class="col-12 col-md-6">
                    <p class="fw-bold mb-1 text-white">Teléfono</p>
                    <p class="mb-0 text-white"><%= cr.telefono.presence || "Sin especificar" %></p>
                  </div>
                  <div class="col-12 col-md-6">
                    <p class="fw-bold mb-1 text-white">DNI</p>
                    <p class="mb-0 text-white"><%= cr.dni.presence || "Sin especificar" %></p>
                  </div>
                  <% if cr.cliente.present? %>
                    <div class="col-12">
                      <p class="fw-bold mb-1 text-white">Cliente registrado</p>
                      <p class="mb-0 text-white"><%= cr.cliente.nombre %> — <%= cr.cliente.email %></p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>

        </div>

        <div class="card-footer border-top border-white d-flex gap-2 justify-content-center py-3">
          <%= link_to edit_reserva_path(@reserva), class: "btn btn-warning fw-bold" do %>
            <i class="fa-solid fa-pen-to-square"></i> Editar reserva
          <% end %>
          <%= link_to edit_clientes_reserva_path(@reserva), class: "btn btn-primary fw-bold" do %>
            <i class="fa-solid fa-user-pen"></i> Editar clientes
          <% end %>
          <%= link_to reservas_path, class: "btn btn-secondary fw-bold" do %>
            <i class="fa-solid fa-arrow-left"></i> Volver
          <% end %>
        </div>

      </div>
    </div>
  </div>
</div>