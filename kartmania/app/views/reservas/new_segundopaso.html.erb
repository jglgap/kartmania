<div class="container py-4 custom-user-form mb-4 px-3 px-lg-5">
  <div class="row justify-content-center">
    <h1 class="mb-4 fw-bold text-white text-center text-md-start">Nueva Reserva</h1>
    <div class="col-12 col-lg-8 col-xl-6">

      <% if @reserva.cliente_reservas.any? { |cr| cr.errors.any? } %>
        <div class="alert alert-danger">
          <% @reserva.cliente_reservas.each_with_index do |cr, index| %>
            <% if cr.errors.any? %>
              <p class="fw-bold mb-1">Participante <%= index + 1 %>:</p>
              <% cr.errors.full_messages.each do |msg| %>
                <p class="mb-0 ms-2"><%= msg %></p>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="d-flex justify-content-center gap-3 mb-4">
        <span class="btn btn-outline-light fw-bold px-4 disabled">Primer paso</span>
        <span class="btn btn-light fw-bold px-4">Segundo paso</span>
      </div>

      <%= form_with url: create_segundopaso_reservas_path(reserva_id: @reserva.id),
          method: :post,
          data: { turbo: false } do |f| %>

        <% @reserva.cliente_reservas.each_with_index do |cr, index| %>

          <div class="card border-white mb-4 custom-card">
            <div class="card-header border-bottom border-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0 text-white">Participante <%= index + 1 %></h5>


            <% if index == 0 %>
                <span class="badge bg-success fw-bold">Titular</span>
                <input type="hidden"
                    name="reserva[cliente_reservas_attributes][0][es_titular]"
                    value="1">
            <% end %>
            </div>

            <div class="card-body">
              <div class="row g-3">


                <input type="hidden"
                       name="reserva[cliente_reservas_attributes][<%= index %>][id]"
                       value="<%= cr.id %>">


                <div class="col-12">
                  <label class="form-label fw-bold text-white">Cliente registrado</label>
                  <select class="form-select cliente-select"
                          data-index="<%= index %>">
                    <option value="">Sin cliente registrado</option>
                    <% @clientes.each do |cliente| %>
                      <option value="<%= cliente.id %>"
                              data-url="<%= datos_cliente_path(cliente) %>">
                        <%= cliente.nombre %> — <%= cliente.email %>
                      </option>
                    <% end %>
                  </select>
                </div>


                <input type="hidden"
                       name="reserva[cliente_reservas_attributes][<%= index %>][cliente_id]"
                       id="cliente_id_<%= index %>">

                <div class="col-12 col-md-6">
                  <label class="form-label fw-bold text-white">Nombre<i class="fa-solid fa-circle-exclamation ms-1 text-danger "></i></label>
                  <input type="text"
                         name="reserva[cliente_reservas_attributes][<%= index %>][nombre]"
                         id="nombre_<%= index %>"
                         class="form-control"
                         value="<%= cr.nombre %>">
                </div>

                <div class="col-12 col-md-6">
                  <label class="form-label fw-bold text-white">Email<i class="fa-solid fa-circle-exclamation ms-1 text-danger "></i></label>
                  <input type="email"
                         name="reserva[cliente_reservas_attributes][<%= index %>][email]"
                         id="email_<%= index %>"
                         class="form-control"
                         value="<%= cr.email %>">
                </div>

                <div class="col-12 col-md-6">
                  <label class="form-label fw-bold text-white">Teléfono<i class="fa-solid fa-circle-exclamation ms-1 text-danger "></i></label>
                  <input type="text"
                         name="reserva[cliente_reservas_attributes][<%= index %>][telefono]"
                         id="telefono_<%= index %>"
                         class="form-control"
                         value="<%= cr.telefono %>">
                </div>

                <div class="col-12 col-md-6">
                  <label class="form-label fw-bold text-white">DNI<i class="fa-solid fa-circle-exclamation ms-1 text-danger "></i></label>
                  <input type="text"
                         name="reserva[cliente_reservas_attributes][<%= index %>][dni]"
                         id="dni_<%= index %>"
                         class="form-control"
                         value="<%= cr.dni %>">
                </div>

              </div>
            </div>
          </div>

        <% end %>

        <div class="col-12 d-flex gap-2 justify-content-center mt-4">
          <%= link_to "Cancelar", reservas_path, class: "btn btn-danger custom-cancel-button fw-bold" %>
          <button type="submit" class="btn btn-success custom-add-button fw-bold">Crear reserva</button>
        </div>

      <% end %>
    </div>
  </div>
</div>


<script>
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll(".cliente-select").forEach(function(select) {
      select.addEventListener("change", function() {
        const index = this.dataset.index;
        const selectedOption = this.options[this.selectedIndex];
        const url = selectedOption.dataset.url;

        if (!url) {
          document.getElementById("cliente_id_" + index).value = "";
          document.getElementById("nombre_" + index).value = "";
          document.getElementById("email_" + index).value = "";
          document.getElementById("telefono_" + index).value = "";
          return;
        }

        // Usamos XMLHttpRequest en lugar de fetch para evitar conflictos con Turbo
        const xhr = new XMLHttpRequest();
        xhr.open("GET", url);
        xhr.setRequestHeader("Accept", "application/json");
        xhr.onload = function() {
          if (xhr.status === 200) {
            const data = JSON.parse(xhr.responseText);
            document.getElementById("cliente_id_" + index).value = selectedOption.value;
            document.getElementById("nombre_" + index).value = data.nombre || "";
            document.getElementById("email_" + index).value = data.email || "";
            document.getElementById("telefono_" + index).value = data.telefono || "";
          }
        };
        xhr.send();
      });
    });
  });
</script>