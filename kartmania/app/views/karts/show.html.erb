<div class="container py-4 px-0 px-md-3 px-lg-5">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">

      <div class="card text-white border-0 custom-card">

        <div class="card-header border-bottom border-white py-3">
          <h2 class="fw-bold mb-0">Kart #<%= @kart.id %></h2>
        </div>

        <div class="card-body">
          <div class="row g-4">

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Tipo</p>
              <p class="mb-0"><%= @kart.tipo.humanize %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Estado</p>
              <span class="badge mt-1 <%= color_estado_kart(@kart) %>">
                <%= @kart.estado.humanize %>
              </span>
              <p class="mb-0"><%= @kart.estado.humanize %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Circuito</p>
              <p class="mb-0"><%= @kart.circuito.present? ? @kart.circuito.nombre : "Sin circuito asignado" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Creado</p>
              <p class="mb-0"><%= @kart.created_at.strftime("%d/%m/%Y") %></p>
            </div>

          </div>
        </div>

        <div class="card-footer border-top border-white d-flex gap-2 justify-content-center py-3">
          <%= link_to edit_kart_path(@kart), class: "btn btn-warning fw-bold" do %>
            <i class="fa-solid fa-pen-to-square"></i>
          <% end %>
          <%= link_to karts_path, class: "btn btn-secondary fw-bold" do %>
            <i class="fa-solid fa-arrow-left"></i> Volver
          <% end %>
        </div>

      </div>
    </div>
  </div>
</div>