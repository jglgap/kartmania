<div class="container py-4 px-3 px-lg-5">
  <h1 class="fw-bold text-white mb-4">Planes</h1>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

    <div id="filtro"></div>

    <%= link_to new_plane_path, class: "btn btn-success custom-add-button fw-bold d-flex align-items-center gap-2" do %>
      <span>Crear</span>
      <i class="fa-solid fa-plus"></i>
    <% end %>

  </div>

  <div class="table-responsive">
    <table id="tabla-searchable" class="table custom-table text-center align-middle">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Precio</th>
          <th>Maximo de participantes</th>
          <th>Circuito</th>
          <th data-orderable="false">Estado</th>
          <th data-searchable="false" data-orderable="false" >Descripción</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @planes.each do |plan| %>
          <tr>
            <td><%= plan.nombre %></td>
            <td><%= plan.precio %></td>
            <td><%= plan.max_participantes %></td>
            <td><%= plan.circuito_id.present? ? plan.circuito.nombre : "Sin circuito asignado" %></td>
            <td><%= plan.estado.humanize %></td>
            <td><%= (plan.descripcion.presence || "No especificada").truncate(50) %></td>
            <td class="text-nowrap">
              <div class="d-flex gap-2 justify-content-center">


                <%= link_to plane_path(plan), class: "btn btn-sm btn-info fw-bold" do %>
                  <i class="fa-solid fa-eye"></i>
                <% end %>

        
                <%= link_to edit_plane_path(plan), class: "btn btn-sm btn-warning fw-bold" do %>
                  <i class="fa-solid fa-pen-to-square"></i>
                <% end %>

                <%= button_to plane_path(plan),
                    method: :delete,
                    data: { turbo: false },
                    class: "btn btn-sm btn-danger fw-bold" do %>
                  <i class="fa-solid fa-trash"></i>
                <% end %>

              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>