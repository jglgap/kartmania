<div class="container-fluid container-md py-4 px-3 px-lg-5">
  <div class="row justify-content-center">
    <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">
    
        <div class="card text-white border-0 custom-card" >

        <div class="card-header border-bottom border-white py-3">
        <h2 class="fw-bold mb-0"><%= @cliente.nombre %></h2>
        </div>


        <div class="card-body">
          <div class="row g-4">
          
            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Email</p>
              <p class="mb-0"><%= @cliente.email %></p>
            </div>
            
            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Teléfono</p>
              <p class="mb-0"><%= @cliente.telefono.presence || "No especificado" %></p>
            </div>
            
            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Dirección</p>
              <p class="mb-0"><%= @cliente.direccion.presence || "No especificada" %></p>
            </div>
            
            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Ciudad</p>
              <p class="mb-0"><%= @cliente.ciudad.presence || "No especificada" %></p>
            </div>
            
            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Provincia</p>
              <p class="mb-0"><%= @cliente.provincia.presence || "No especificada" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Código Postal</p>
              <p class="mb-0"><%= @cliente.codigo_postal.presence || "No especificado" %></p>
            </div>

            
            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Mejor tiempo</p>
              <p class="mb-0"><%= @cliente.mejor_tiempo.presence || "No especificado" %></p>
            </div>

            <div class="col-12 col-md-6">
              <p class="fw-bold mb-1">Miembro desde</p>
              <p class="mb-0"><%= @cliente.created_at.strftime("%d/%m/%Y") %></p>
            </div>

          </div>
        </div>

        <div class="card-footer border-top border-white d-flex gap-2 justify-content-center py-3">
        <%= link_to edit_cliente_cliente_path(current_cliente), class: "btn btn-warning fw-bold" do %>
            <i class="fa-solid fa-pen-to-square"></i>
        <% end %>
        <%= link_to root_path, class: "btn btn-secondary fw-bold" do %>
            <i class="fa-solid fa-arrow-left"></i> Volver
        <% end %>
        </div>


      </div>

    </div>
  </div>
</div>        