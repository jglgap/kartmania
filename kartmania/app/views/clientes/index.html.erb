<div class="container py-4 px-3 px-lg-5">
  <h1 class="fw-bold text-white mb-4">Clientes</h1>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">

    <div id="filtro"></div>
    
    <%= link_to new_cliente_path, class: "btn btn-success custom-add-button fw-bold d-flex align-items-center gap-2" do %>
        <span>Crear</span>
        <i class="fa-solid fa-plus"></i>
    <% end %>
  </div>


  <div class="table-responsive">
    <table id="tabla-searchable" class="table custom-table text-center align-middle">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Email</th>
          <th data-orderable="false">Teléfono</th>
          <th data-searchable="false">Mejor tiempo</th>
          <th data-orderable="false">Ciudad</th>
          <th data-orderable="false"x>Provincia</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @clientes.each do |cliente| %>
          <tr>
            <td><%= cliente.nombre %></td>
            <td><%= cliente.email %></td>
            <td><%= cliente.telefono.present? ? cliente.telefono : "no especificado" %></td>
            <td><%= cliente.mejor_tiempo.present? ? cliente.mejor_tiempo : "0" %></td>
            <td><%= cliente.ciudad.present? ? cliente.ciudad : "no especificado" %></td>
            <td><%= cliente.provincia&.nombre || "No especificada"%></td>
            <td class="text-nowrap">
            <div class="d-flex gap-2 justify-content-center">
                <%= link_to cliente_path(cliente), class: "btn btn-sm btn-info fw-bold" do %>
                <i class="fa-solid fa-eye"></i>
                <% end %>

                <%= link_to edit_cliente_path(cliente), class: "btn btn-sm btn-warning fw-bold" do %>
                <i class="fa-solid fa-pen-to-square"></i>
                <% end %>

                <%= button_to cliente_path(cliente),
                    method: :delete,
                    data: { turbo: false},
                    class: "btn btn-sm btn-danger fw-bold" do %>
                <i class="fa-solid fa-trash"></i>
                <% end %>
            </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>