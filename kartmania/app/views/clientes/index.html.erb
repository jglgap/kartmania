<div class="container py-4 px-3 px-lg-5">
  <h1 class="fw-bold text-white mb-4">Clientes</h1>

  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">


    <%= form_with url: clientes_path, method: :get, data: { turbo: false } do |f| %>
      <div class="input-group">
        <%= f.text_field :search,
            value: params[:search],
            placeholder: "Filtrar",
            class: "form-control" %>
        <%= f.button type: :submit, class: "btn btn-outline-light" do %>
            <i class="fa-solid fa-magnifying-glass"></i>
        <% end %>
      </div>
    <% end %>

    
    <%= link_to new_cliente_path, class: "btn btn-success custom-add-button fw-bold d-flex align-items-center gap-2" do %>
        <span>Crear</span>
        <i class="fa-solid fa-plus"></i>
    <% end %>
  </div>


  <div class="table-responsive">
    <table id="tabla-user" class="table custom-table text-center align-middle">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Email</th>
          <th>Teléfono</th>
          <th>Tipo</th>
          <th>Ciudad</th>
          <th>Provincia</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @clientes.each do |cliente| %>
          <tr>
            <td><%= cliente.nombre %></td>
            <td><%= cliente.email %></td>
            <td><%= cliente.telefono %></td>
            <td><%= cliente.mejor_tiempo %></td>
            <td><%= cliente.ciudad %></td>
            <td><%= cliente.provincia&.nombre || "No especificada"%></td>
            <td class="text-nowrap">
            <div class="d-flex gap-2 justify-content-center">
                <%= link_to cliente_path(cliente), class: "btn btn-sm btn-info fw-bold" do %>
                <i class="fa-solid fa-eye"></i>
                <% end %>

                <%= link_to edit_cliente_path(cliente), class: "btn btn-sm btn-warning fw-bold" do %>
                <i class="fa-solid fa-pen-to-square"></i>
                <% end %>

                <%= button_to cliente_path(cliente),
                    method: :delete,
                    data: { turbo: false},
                    class: "btn btn-sm btn-danger fw-bold" do %>
                <i class="fa-solid fa-trash"></i>
                <% end %>
            </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>