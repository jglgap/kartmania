<div class="min-vh-100 d-flex align-items-center justify-content-center">
  <div class="w-100" style="max-width: 420px; padding: 1.5rem;">

    <div class="text-center mb-4">
      <h1 class="fw-bold text-white">Kartmania</h1>
      <p class="text-white-50">Área de clientes</p>
    </div>

    <div class="card border-0 custom-card">
      <div class="card-body p-4">

        <h2 class="fw-bold text-white text-center mb-2">Recuperar contraseña</h2>
        <p class="text-white-50 text-center small mb-4">
          Te enviaremos un email con las instrucciones.
        </p>

        <%= form_with url: cliente_password_path, method: :post, data: { turbo: false } do |f| %>

          <div class="mb-4">
            <%= f.label :email, "Email", class: "form-label fw-bold text-white" %>
            <%= f.email_field :email,
                name: "cliente[email]",
                autofocus: true,
                autocomplete: "email",
                class: "form-control",
                placeholder: "tu@email.com" %>
          </div>

          <%= f.submit "Enviar instrucciones", class: "btn btn-success custom-add-button fw-bold w-100" %>

        <% end %>

        <hr class="border-white-50 my-3">

        <div class="text-center d-flex flex-column gap-2">
          <%= link_to "Volver al inicio de sesión",
              new_cliente_session_path,
              class: "text-white-50 small" %>
          <%= link_to "¿No tienes cuenta? Regístrate",
              new_cliente_registration_path,
              class: "text-white-50 small" %>
        </div>

      </div>
    </div>

  </div>
</div>